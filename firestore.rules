rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin Check: Verify against hardcoded email OR Firestore role
    function isAdmin() {
      let isSystemAdmin = request.auth.token.email == "projetocontratosfacul@gmail.com" && isEmailVerified();
      let hasAdminDoc = exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      return isSystemAdmin || hasAdminDoc;
    }
    
    function isManager() {
      let hasManagerDoc = exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
      return isAdmin() || hasManagerDoc;
    }

    // ID Validation helper
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid) && 
                      request.resource.data.role == 'viewer' && 
                      request.resource.data.uid == uid &&
                      request.resource.data.email == request.auth.token.email;
      allow update: if isAdmin() || (isOwner(uid) && request.resource.data.role == resource.data.role);
    }

    match /suppliers/{supplierId} {
      allow read: if isSignedIn();
      allow create: if isManager() && 
                      request.resource.data.keys().hasAll(['name', 'contactEmail', 'createdAt']) &&
                      request.resource.data.name is string &&
                      request.resource.data.name.size() > 0;
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow create: if isManager() && 
                      request.resource.data.keys().hasAll(['contractNumber', 'name', 'supplierId', 'status', 'createdAt']) &&
                      isValidId(request.resource.data.supplierId);
      allow update: if isManager();
      allow delete: if isAdmin();
      
      match /slas/{slaId} {
        allow read: if isSignedIn();
        allow write: if isManager();
      }
    }

    match /incidents/{incidentId} {
      allow read: if isSignedIn();
      allow create: if isManager() && 
                      request.resource.data.keys().hasAll(['contractId', 'system', 'priority', 'status', 'openedAt']) &&
                      isValidId(request.resource.data.contractId);
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow write: if isAdmin();
    }
  }
}
